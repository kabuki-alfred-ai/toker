# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=viralscript
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=viralscript
# En dev local seulement (le docker-compose prod le construit automatiquement)
DATABASE_URL=postgresql://viralscript:change_me@localhost:5433/viralscript

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────────────────────────────────────────────
# Minimum 32 caractères aléatoires — générer avec : openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRATION=7d

# ── APIs externes ──────────────────────────────────────────────────────────────
GOOGLE_VISION_API_KEY=
YOUTUBE_API_KEY=
# OpenAI (backend uniquement)
OPENAI_API_KEY=sk-...

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── SocialKit (primary transcription provider) ───────────────────────────────
# Get your API key at https://www.socialkit.dev — 20 free credits included
SOCIALKIT_API_KEY=

# ── Proxy (optional, recommended for production) ─────────────────────────────
# Residential/mobile proxy to avoid IP bans (BrightData, Oxylabs, SmartProxy)
# Format: socks5://user:pass@host:port or http://user:pass@host:port
PROXY_URL=

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
BACKEND_PORT=3001
# En prod Coolify : http://backend:3001 (réseau Docker interne)
BACKEND_URL=http://backend:3001
