# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=viralscript
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=viralscript
# En dev local seulement (le docker-compose prod le construit automatiquement)
DATABASE_URL=postgresql://viralscript:change_me@localhost:5433/viralscript

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────────────────────────────────────────────
# Minimum 32 caractères aléatoires — générer avec : openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRATION=7d

# ── APIs externes ──────────────────────────────────────────────────────────────
GOOGLE_VISION_API_KEY=
YOUTUBE_API_KEY=
# Gemini (source finder — requis pour que le source finder fonctionne)
GEMINI_API_KEY=
# OpenAI (backend uniquement)
OPENAI_API_KEY=sk-...

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── SocialKit (primary transcription provider) ───────────────────────────────
# Get your API key at https://www.socialkit.dev — 20 free credits included
SOCIALKIT_API_KEY=

# ── Replicate (subtitle removal via GPU) ─────────────────────────────────────
# Get your token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
# Après `cog push`, copie le model ID affiché (format: username/video-subtitle-remover:sha256hash)
REPLICATE_VSR_MODEL=

# ── RustFS (S3-compatible object storage) ────────────────────────────────
# En dev local : http://localhost:9000 | En prod Docker : http://rustfs:9000
STORAGE_ENDPOINT=http://localhost:9000
# URL publique accessible depuis internet — requis pour Replicate (ex: https://storage.yourdomain.com ou ngrok)
# En prod, pointer sur le reverse proxy devant RustFS. Laisser vide si non utilisé.
STORAGE_PUBLIC_URL=
# Générer avec : openssl rand -hex 16
STORAGE_ACCESS_KEY=rustfs_admin
STORAGE_SECRET_KEY=change_me_strong_password
STORAGE_BUCKET=viralscript
STORAGE_REGION=us-east-1

# ── Proxy (optional, recommended for production) ─────────────────────────────
# Residential/mobile proxy to avoid IP bans (BrightData, Oxylabs, SmartProxy)
# Format: socks5://user:pass@host:port or http://user:pass@host:port
PROXY_URL=

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
BACKEND_PORT=3001
# En prod Coolify : http://backend:3001 (réseau Docker interne)
BACKEND_URL=http://backend:3001
