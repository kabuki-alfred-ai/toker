// backend/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum CreditTransactionReason {
  TRANSCRIPTION_USED
  TRANSCRIPTION_REFUND
  SOURCE_FINDER_USED
  SOURCE_FINDER_REFUND
  DOWNLOAD_USED
  DOWNLOAD_REFUND
  SUBTITLE_REMOVAL_USED
  SUBTITLE_REMOVAL_REFUND
  SUBTITLE_GENERATION_USED
  SUBTITLE_GENERATION_REFUND
  PURCHASE
  WEEKLY_RESET
}

enum SubtitleRemovalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DownloadStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DownloadFormat {
  mp4
  mp3
  webm
  m4a
}

enum DownloadQuality {
  q240p
  q360p
  q480p
  q720p
  q1080p
}

enum SourceSearchStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum TranscriptionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SubtitleGenerationStatus {
  PENDING
  TRANSCRIBING
  TRANSCRIBED
  RENDERING
  COMPLETED
  FAILED
}

enum SubtitlePreset {
  BOLD_SHADOW
  KARAOKE
  PILL
  OUTLINE
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  password             String
  firstName            String?
  lastName             String?
  role                 Role                 @default(USER)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  transcriptions       Transcription[]
  sourceSearches       SourceSearch[]
  downloads            Download[]
  subtitleRemovals     SubtitleRemoval[]
  subtitleGenerations  SubtitleGeneration[]
  creditWallet         CreditWallet?
  creditTransactions   CreditTransaction[]
  passwordResetTokens  PasswordResetToken[]

  @@map("users")
}

model CreditWallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_wallets")
}

model CreditTransaction {
  id          String                    @id @default(cuid())
  userId      String
  amount      Int                       // positive = credit, negative = debit
  reason      CreditTransactionReason
  description String?
  createdAt   DateTime                  @default(now())
  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_transactions")
}

model Transcription {
  id        String              @id @default(cuid())
  userId    String
  videoUrl  String
  title     String?             // Video title from yt-dlp metadata
  duration  Int?                // Duration in seconds
  text      String?
  segments  Json?               // Array of { start: number, end: number, text: string }
  keywords  Json?               // Array of strings extracted by GPT-4o-mini
  status    TranscriptionStatus @default(PENDING)
  errorMsg  String?
  audioUuid String? // Cache UUID : skip yt-dlp si déjà téléchargé (FR11)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transcriptions")
}

model SourceSearch {
  id        String             @id @default(cuid())
  userId    String
  videoUrl  String
  status    SourceSearchStatus @default(PENDING)
  errorMsg  String?
  sources   Json?              // Array of { url, title, thumbnailUrl, timestamp, confidence, type }
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("source_searches")
}

model Download {
  id          String          @id @default(cuid())
  userId      String
  videoUrl    String
  title       String?
  thumbnail   String?
  format      DownloadFormat  @default(mp4)
  quality     DownloadQuality @default(q360p)
  downloadUrl String?
  storageKey  String?         // RustFS bucket path — used to generate presigned URLs
  fileSize    String?
  duration    String?
  status      DownloadStatus  @default(PENDING)
  errorMsg    String?
  expiresAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("downloads")
}

model SubtitleRemoval {
  id         String                @id @default(cuid())
  userId     String
  videoUrl   String
  outputUrl  String?
  storageKey String?               // RustFS bucket path — used to generate presigned URLs
  status     SubtitleRemovalStatus @default(PENDING)
  errorMsg   String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subtitle_removals")
}

model SubtitleGeneration {
  id              String                   @id @default(cuid())
  userId          String
  videoUrl        String
  preset          SubtitlePreset           @default(KARAOKE)
  customization   Json?
  wordSegments    Json?
  status          SubtitleGenerationStatus @default(PENDING)
  errorMsg        String?
  storageKey      String?
  inputStorageKey String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subtitle_generations")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}
